<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /sibudi/
    
    # Don't rewrite if it's the source/public directory itself
    RewriteCond %{REQUEST_URI} ^/sibudi/source/public/ [OR]
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]
    
    # Rewrite to source/public/index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ source/public/index.php [L]
</IfModule>

